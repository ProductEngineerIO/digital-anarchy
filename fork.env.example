# ============================================================
# World Monitor — Fork Environment Variables (fork.env.example)
# ============================================================
# This file documents ALL environment variables used by this fork,
# including upstream-inherited vars and fork-specific additions.
#
# Copy to .env.local and fill in the values you need:
#
#   cp fork.env.example .env.local
#
# Deployment targets:
#   Vercel    — Next.js edge functions & SSR (primary production host)
#   Railway   — Persistent relay server and seed cron jobs
#   Desktop   — Tauri sidecar (local-api-server.mjs), user-configured at runtime
#
# Marking conventions:
#   # REQUIRED  — service or panel will error / fail to start without this
#   # OPTIONAL — panel degrades gracefully (stale data, reduced features, or feature hidden)
#
# ============================================================


# ============================================================
# AI SUMMARIZATION
# Used by: Vercel edge functions (news summarization, situation analysis)
# ============================================================

# OPTIONAL — AI summaries and situation reports will be unavailable without at least one provider.

# Groq API (primary LLM provider — 14,400 req/day on free tier)
# Register at: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API (fallback LLM provider — 50 req/day on free tier)
# Register at: https://openrouter.ai/
OPENROUTER_API_KEY=

# Custom LLM override — set all three to point Situation Deduction at a custom provider.
# Falls back to GROQ_API_KEY / Groq endpoint if unset.
# OPTIONAL — falls back to GROQ_API_KEY
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=

# Ollama local LLM server (used for on-device news summarization via /api/summarize)
# Desktop: user sets OLLAMA_API_URL at runtime via Settings panel.
# Vercel:  set these if you self-host an Ollama endpoint reachable from Vercel edge.
# OPTIONAL — panel falls back to Groq/OpenRouter when unset
OLLAMA_API_URL=
OLLAMA_MODEL=llama3.1:8b
# Optional bearer token for Ollama servers that require authentication.
OLLAMA_API_KEY=
# Maximum tokens per Ollama response (default: 300).
OLLAMA_MAX_TOKENS=300


# ============================================================
# CROSS-USER CACHE (Upstash Redis)
# Used by: All Vercel edge functions (deduplication + seed data reads)
# ============================================================

# REQUIRED for production — panels that rely on seed data (earthquakes, outages,
# market quotes, etc.) will return empty without Redis hydration.

# Create a free Redis database at: https://upstash.com/
# Note: production and preview deployments share the same instance;
#       ARCH-29 key prefix (VERCEL_ENV + VERCEL_GIT_COMMIT_SHA) prevents collisions.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ============================================================
# MARKET DATA
# Used by: Vercel edge functions (stocks, crypto, commodities, ETFs)
# ============================================================

# Finnhub — primary stock quote provider (free tier available)
# Register at: https://finnhub.io/
# OPTIONAL — market panel shows stale seed data without this
FINNHUB_API_KEY=


# ============================================================
# ENERGY DATA
# Used by: Vercel edge functions (oil prices, production, inventory)
# ============================================================

# U.S. Energy Information Administration
# Register at: https://www.eia.gov/opendata/
# OPTIONAL — energy panel shows stale/empty without this
EIA_API_KEY=


# ============================================================
# ECONOMIC DATA
# Used by: Vercel edge functions (macro signals, interest rates, GDP)
# ============================================================

# FRED — Federal Reserve Economic Data
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
# OPTIONAL — macro signals panel shows stale data without this
FRED_API_KEY=

# WTO — World Trade Organization API (tariff schedules, trade policy)
# Register at: https://apiportal.wto.org/
# OPTIONAL — trade policy panel hidden without this; Desktop users can set at runtime
WTO_API_KEY=


# ============================================================
# AVIATION INTELLIGENCE
# Used by: Vercel edge functions (delays, NOTAMs, carrier ops)
# ============================================================

# AviationStack — live flight data, airport departures/arrivals, carrier ops
# Register at: https://aviationstack.com/
# OPTIONAL — aviation panel shows stale seed data without this
AVIATIONSTACK_API=

# ICAO API — NOTAM airport closures (MENA region focus)
# Register at: https://applications.icao.int/
# OPTIONAL — NOTAM layer hidden without this
ICAO_API_KEY=

# Travelpayouts — flight price search (demo/PRO feature only)
# Register at: https://www.travelpayouts.com/
# OPTIONAL — flight price widget hidden without this
TRAVELPAYOUTS_API_TOKEN=


# ============================================================
# AIRCRAFT TRACKING
# Used by: Vercel edge functions + Railway relay (aircraft enrichment)
# ============================================================

# Wingbits — aircraft owner/operator/type enrichment
# Contact: https://wingbits.com/
# OPTIONAL — aircraft tooltips will show reduced metadata without this
WINGBITS_API_KEY=


# ============================================================
# CONFLICT & PROTEST DATA
# Used by: Vercel edge functions + Railway seed scripts
# ============================================================

# ACLED — Armed Conflict Location & Event Data (free for researchers)
# Register at: https://acleddata.com/
# OPTIONAL — conflict panel shows stale seed data without this
ACLED_ACCESS_TOKEN=

# UCDP — Uppsala Conflict Data Program (access token required since 2025)
# Register at: https://ucdp.uu.se/apidocs/
# OPTIONAL — UCDP event panel shows stale seed data without this
UCDP_ACCESS_TOKEN=
# Legacy alias accepted by seed-ucdp-events.mjs (fallback only)
# UC_DP_KEY=


# ============================================================
# CYBERSECURITY THREATS
# Used by: Vercel edge functions + Railway relay (cyber:threats-bootstrap:v2)
# ============================================================

# All three providers are optional; the threats panel aggregates available sources.
# Desktop users can set these at runtime via Settings → Cybersecurity.

# URLhaus — malware URL threat intelligence (abuse.ch)
# Register at: https://auth.abuse.ch/
# OPTIONAL — URLhaus threat source skipped without this
URLHAUS_AUTH_KEY=

# AlienVault OTX — open threat exchange (IPv4 IOC feeds)
# Register at: https://otx.alienvault.com/
# OPTIONAL — OTX threat source skipped without this
OTX_API_KEY=

# AbuseIPDB — IP reputation and blacklist API
# Register at: https://www.abuseipdb.com/login
# OPTIONAL — AbuseIPDB threat source skipped without this
ABUSEIPDB_API_KEY=


# ============================================================
# INTERNET OUTAGES
# Used by: Vercel edge functions (infrastructure outages panel)
# ============================================================

# Cloudflare Radar API (requires free Cloudflare account with Radar access)
# OPTIONAL — outages panel shows stale seed data without this
CLOUDFLARE_API_TOKEN=


# ============================================================
# SATELLITE FIRE DETECTION
# Used by: Vercel edge functions + Railway seed scripts (wildfire:fires:v1)
# ============================================================

# NASA FIRMS — Fire Information for Resource Management System
# Register at: https://firms.modaps.eosdis.nasa.gov/
# OPTIONAL — wildfire panel shows stale seed data without this
NASA_FIRMS_API_KEY=
# Legacy alias accepted by seed-fire-detections.mjs (fallback only)
# FIRMS_API_KEY=


# ============================================================
# RAILWAY RELAY SERVICE (scripts/ais-relay.cjs)
# Used by: Railway persistent service (AIS + OpenSky + RSS + Cyber + Telegram)
# ============================================================
# Deploy with: node scripts/ais-relay.cjs
# The relay handles: live AIS vessel positions, OpenSky aircraft data,
# RSS proxy caching, cyber threat seeding, and Telegram OSINT polling.

# AISStream — live AIS vessel positions via WebSocket
# Register at: https://aisstream.io/
# OPTIONAL for relay — vessel tracking disabled without this
AISSTREAM_API_KEY=

# OpenSky Network OAuth2 credentials (higher rate limits for cloud IPs)
# Register at: https://opensky-network.org/
# OPTIONAL for relay — falls back to public (unauthenticated) OpenSky API
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=


# ============================================================
# TELEGRAM OSINT (Railway relay)
# Used by: Railway relay (stateful MTProto Telegram poller)
# ============================================================

# Telegram MTProto app keys (free): https://my.telegram.org/apps
# OPTIONAL — Telegram OSINT poller disabled without these
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# GramJS StringSession generated locally:
#   node scripts/telegram/session-auth.mjs
TELEGRAM_SESSION=

# Which curated channel bucket to ingest: full | tech | finance
TELEGRAM_CHANNEL_SET=full


# ============================================================
# RAILWAY RELAY CONNECTION (Vercel → Railway)
# Used by: Vercel edge functions that proxy to the Railway relay
# ============================================================

# Server-side HTTPS URL of the Railway relay (used by Vercel edge functions)
# REQUIRED if using the Railway relay; leave empty to disable relay features
WS_RELAY_URL=

# Client-side WebSocket URL (wss://) — local/dev fallback only
# OPTIONAL — leave empty in production (client uses Vercel proxy instead)
VITE_WS_RELAY_URL=

# Shared secret between Vercel and Railway relay.
# REQUIRED if WS_RELAY_URL is set — must match RELAY_SHARED_SECRET on Railway.
RELAY_SHARED_SECRET=

# Header name used to send the relay secret (must match on both platforms)
RELAY_AUTH_HEADER=x-relay-key

# Emergency production override to allow unauthenticated relay traffic.
# Leave unset or false in production.
ALLOW_UNAUTHENTICATED_RELAY=false

# Rolling window size (seconds) used by relay /metrics endpoint
RELAY_METRICS_WINDOW_SECONDS=60


# ============================================================
# SEED FALLBACK FLAGS
# Used by: Vercel edge functions (controls live-fetch fallback behavior)
# ============================================================
# By default, each domain reads from the Redis seed key.
# When a seed key is missing or stale AND the corresponding SEED_FALLBACK_*
# flag is set to a non-empty value, the edge function will attempt a live fetch.
#
# In production: leave ALL unset — seed data is authoritative.
# In development/staging: set to "1" to enable live fetching without a Railway cron.
#
# OPTIONAL — live fetch disabled by default; panels show seed data (or empty on first deploy)

SEED_FALLBACK_CYBER=
SEED_FALLBACK_DISPLACEMENT=
SEED_FALLBACK_EARTHQUAKES=
SEED_FALLBACK_ETF=
SEED_FALLBACK_FAA=
SEED_FALLBACK_GULF=
SEED_FALLBACK_CLIMATE=
SEED_FALLBACK_CRYPTO=
SEED_FALLBACK_NATURAL=
SEED_FALLBACK_NOTAM=
SEED_FALLBACK_OUTAGES=
SEED_FALLBACK_STABLECOINS=
SEED_FALLBACK_UNREST=
SEED_FALLBACK_WILDFIRES=


# ============================================================
# PUBLIC DATA SOURCES (no keys required)
# ============================================================
# The following sources are used without authentication:
#   UNHCR (UN Refugee Agency)      — public API, CC BY 4.0
#   Open-Meteo                     — public API (Copernicus ERA5)
#   WorldPop                       — public API
#   GpsJam.org                     — public CSV (GPS interference data)
#   USGS Earthquake Hazards        — public feed
#   GDACS                          — public natural disaster feed
#   Feodo Tracker                  — public C2 threat feed (no key)
#   C2 Intel                       — public malware C2 list (no key)


# ============================================================
# SITE CONFIGURATION
# Used by: Vite build (VITE_ prefix) and Vercel runtime
# ============================================================

# Site variant: "full" (worldmonitor.app), "tech" (tech.worldmonitor.app),
#               "finance", or "happy"
VITE_VARIANT=full

# API base URL for browser fetch calls to /api/*.
# Leave empty for same-domain API (default local installs).
# Production: https://api.worldmonitor.app
VITE_WS_API_URL=

# Client-side Sentry DSN for error tracking.
# OPTIONAL — error reporting disabled when empty
VITE_SENTRY_DSN=

# Map interaction mode: "flat" (2D only) or "3d" (pitch/rotation enabled)
VITE_MAP_INTERACTION_MODE=3d

# Enable AIS maritime tracking layer in the client
# OPTIONAL — leave unset to use deployment default
VITE_ENABLE_AIS=

# Enable cybersecurity threat layer in the client
# OPTIONAL
VITE_ENABLE_CYBER_LAYER=

# Route RSS feeds directly to the relay server (bypass Vercel proxy)
# OPTIONAL — leave unset for standard routing
VITE_RSS_DIRECT_TO_RELAY=


# ============================================================
# DESKTOP CLOUD FALLBACK
# Used by: Vercel edge functions (api/_api-key.js) for Tauri desktop app
# ============================================================

# Comma-separated list of valid API keys for desktop cloud fallback requests.
# Generate with: openssl rand -hex 24 | sed 's/^/wm_/'
# OPTIONAL — desktop cloud fallback disabled without this
WORLDMONITOR_VALID_KEYS=


# ============================================================
# REGISTRATION DB (Convex)
# Used by: Vercel edge functions (email registration + waitlist)
# ============================================================

# Convex deployment URL for registration storage.
# Set up at: https://dashboard.convex.dev/
# OPTIONAL — email registration feature disabled without this
CONVEX_URL=


# ============================================================
# VERCEL SYSTEM VARIABLES (auto-injected — do not set manually)
# ============================================================
# These are injected automatically by Vercel and must NOT be set in .env files.
# They are documented here for reference only.
#
#   VERCEL_ENV              — "production" | "preview" | "development"
#   VERCEL_GIT_COMMIT_SHA   — Full git SHA of the deployed commit
#   NODE_ENV                — "production" | "development" | "test"
#
# The Redis key prefix (ARCH-29) is computed from VERCEL_ENV + VERCEL_GIT_COMMIT_SHA
# to isolate preview deployments from production cache data.


